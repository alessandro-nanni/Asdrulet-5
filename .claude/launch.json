{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "backend\\mvnw.cmd",
      "runtimeArgs": [
        "-f",
        "backend/pom.xml",
        "spring-boot:run",
        "-Dspring-boot.run.jvmArguments=-Dapp.dev-tools.enabled=true"
      ],
      "port": 8080
    },
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "frontend",
      "port": 5173
    }
  ]
}
